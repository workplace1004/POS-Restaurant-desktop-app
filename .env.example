# Optional Vite overrides (copy to `.env` or `.env.local`).

# Electron (unpackaged / `npm run electron`): auto-starts `backend` + `device` from this repo.
# Set to 1 to disable and run servers yourself (e.g. `npm run dev`).
# ELECTRON_NO_EMBEDDED_SERVERS=1
# Log server stdout/stderr in the terminal that launched Electron:
# ELECTRON_SERVICE_LOG=1

# Open Chromium DevTools when the window loads (in addition to F12 / Ctrl+Shift+I toggle).
# ELECTRON_OPEN_DEVTOOLS=1

# Remote debugging for the renderer: in Chrome open chrome://inspect → Configure → add localhost:9222 (or your port).
# ELECTRON_REMOTE_DEBUG_PORT=9222

# REST API base URL when the UI is not same-origin as the API (optional; Electron file:// defaults to http://127.0.0.1:5000/api in src/lib/apiOrigin.js).
# Example: http://127.0.0.1:5000/api — must match where `backend` listens (default port 5000).
# VITE_API_URL=http://127.0.0.1:5000/api

# Standalone license API (deploy license-server online). If unset, dev uses Vite proxy /license → localhost:5050.
# VITE_LICENSE_API_URL=https://your-license-api.example.com

# Local hardware ID agent (motherboard / system DMI on this PC). Default: same-origin
# `/device-agent/device-id` — in dev, Vite proxies that to http://127.0.0.1:39471.
# Run the agent: `npm run device-agent` from this folder (or `npm start` in ../device-agent).
# Production HTTPS: point this at a URL your reverse proxy forwards to 127.0.0.1:39471.
# VITE_DEVICE_AGENT_URL=http://127.0.0.1:39471

# RSA public key (PEM) for offline license verification after first activation.
# Must match the private key used by your deployed license API (generate keys in that service, e.g. license-server: npm run license:keys).
# Use literal newlines or \n escapes in a single line.
# VITE_LICENSE_RSA_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Electron: license gating also uses `window.posLicense` when present.

# Same 64 hex chars as LICENSE_FILE_ENCRYPTION_KEY on license-server (decrypts issuer "licenseKey" file).
# VITE_LICENSE_FILE_ENCRYPTION_KEY=

# After activation, the encrypted license is stored in the browser (Origin Private File System: pos-restaurant/licenseKey).
# Startup checks that file + RSA only — no license-server database call. Requires a secure context (https or localhost).
