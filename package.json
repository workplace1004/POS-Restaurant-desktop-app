{
  "name": "pos-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "vite build --base ./",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:debug": "cross-env ELECTRON_OPEN_DEVTOOLS=1 electron --inspect=9229 .",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_USE_DEV_SERVER=1 electron .\"",
    "electron:prepare-embedded": "node scripts/prepare-embedded.cjs",
    "electron:stage-license-env": "node scripts/stage-license-env.cjs",
    "electron:build": "npm run build:electron && npm run electron:prepare-embedded && npm run electron:stage-license-env && electron-builder"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.respos.desktop",
    "productName": "RES POS",
    "icon": "public/icon.png",
    "artifactName": "${productName} Setup ${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "embedded-staging/backend",
        "to": "embedded/backend"
      },
      {
        "from": "embedded-staging/device",
        "to": "embedded/device"
      },
      {
        "from": "embedded-staging/node-runtime",
        "to": "embedded/node-runtime"
      },
      {
        "from": "embedded-staging/license.env",
        "to": "license.env"
      }
    ],
    "nsis": {
      "include": "electron/installer.nsh",
      "shortcutName": "RES POS",
      "uninstallDisplayName": "RES POS",
      "perMachine": true,
      "allowElevation": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "executableName": "RES POS"
    }
  }
}
